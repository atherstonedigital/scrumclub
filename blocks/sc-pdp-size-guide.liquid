{%- comment -%}
  sc-pdp-size-guide.liquid — PDP size-guide link (CLAUDE.md §3.2 / CRO)
  ------------------------------------------------------------------
  Small Saira link sitting under the size pills. Reduces size anxiety
  (a top PDP drop-off) by pointing to the size-guide page. No inline
  size table — the cm storage format is an open decision (§6 #2), so we
  link out rather than invent one. Theme block.
{%- endcomment -%}

<a class="sc-size-link" href="{{ block.settings.link | default: '/pages/size-guide' }}" {{ block.shopify_attributes }}>
  <svg class="sc-size-link__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
    <rect x="2" y="7" width="20" height="10" rx="1"/>
    <path d="M7 7v3M12 7v4M17 7v3"/>
  </svg>
  <span>{{ block.settings.label | default: 'Size guide' | escape }}</span>
</a>

{% stylesheet %}
  .sc-size-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-action);
    font-weight: 800;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 12px;
    color: var(--steel);
    text-decoration: none;
    border-bottom: 1px solid var(--bone);
    padding-bottom: 1px;
    transition: color var(--dur-fast, 160ms) var(--ease-tackle, ease),
                border-color var(--dur-fast, 160ms) var(--ease-tackle, ease);
  }
  .sc-size-link:hover { color: var(--try); border-color: var(--try); }
  .sc-size-link__icon { width: 16px; height: 16px; stroke-linecap: round; stroke-linejoin: round; }
  .sc-pitch .sc-size-link, .sc-mud .sc-size-link { color: var(--chalk); }
{% endstylesheet %}

{% schema %}
{
  "name": "SC PDP Size Guide Link",
  "tag": null,
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Size guide" },
    { "type": "url", "id": "link", "label": "Link", "default": "/pages/size-guide" }
  ],
  "presets": [ { "name": "SC PDP Size Guide Link", "category": "Scrum Club" } ]
}
{% endschema %}
