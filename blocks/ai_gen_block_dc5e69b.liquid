{% doc %}
  @prompt
    i need trust signals, fast delivery, UK made, 5% giveback to Rugby, designed by players for players.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-signals-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-trust-signals-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-trust-signal-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.alignment }};
    text-align: {{ block.settings.alignment }};
    gap: {{ block.settings.item_gap }}px;
  }

  .ai-trust-signal-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    color: {{ block.settings.icon_color }};
  }

  .ai-trust-signal-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
    stroke-width: {{ block.settings.icon_stroke_width }};
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-trust-signal-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-trust-signal-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0;
  }

  .ai-trust-signal-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-signals-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-trust-signal-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-trust-signal-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-trust-signal-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-trust-signals-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-signals-grid-{{ ai_gen_id }}">
    {% if block.settings.show_fast_delivery %}
      <div class="ai-trust-signal-item-{{ ai_gen_id }}">
        <div class="ai-trust-signal-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
        </div>
        <div class="ai-trust-signal-content-{{ ai_gen_id }}">
          <p class="ai-trust-signal-title-{{ ai_gen_id }}">{{ block.settings.fast_delivery_title }}</p>
          <p class="ai-trust-signal-text-{{ ai_gen_id }}">{{ block.settings.fast_delivery_text }}</p>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_uk_made %}
      <div class="ai-trust-signal-item-{{ ai_gen_id }}">
        <div class="ai-trust-signal-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 2v20M2 12h20M12 2c-2.5 3-2.5 9 0 12M12 2c2.5 3 2.5 9 0 12M2 12c3-2.5 9-2.5 12 0M2 12c3 2.5 9 2.5 12 0"/>
          </svg>
        </div>
        <div class="ai-trust-signal-content-{{ ai_gen_id }}">
          <p class="ai-trust-signal-title-{{ ai_gen_id }}">{{ block.settings.uk_made_title }}</p>
          <p class="ai-trust-signal-text-{{ ai_gen_id }}">{{ block.settings.uk_made_text }}</p>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_giveback %}
      <div class="ai-trust-signal-item-{{ ai_gen_id }}">
        <div class="ai-trust-signal-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </div>
        <div class="ai-trust-signal-content-{{ ai_gen_id }}">
          <p class="ai-trust-signal-title-{{ ai_gen_id }}">{{ block.settings.giveback_title }}</p>
          <p class="ai-trust-signal-text-{{ ai_gen_id }}">{{ block.settings.giveback_text }}</p>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_designed_by_players %}
      <div class="ai-trust-signal-item-{{ ai_gen_id }}">
        <div class="ai-trust-signal-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <div class="ai-trust-signal-content-{{ ai_gen_id }}">
          <p class="ai-trust-signal-title-{{ ai_gen_id }}">{{ block.settings.designed_by_players_title }}</p>
          <p class="ai-trust-signal-text-{{ ai_gen_id }}">{{ block.settings.designed_by_players_text }}</p>
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Trust signals",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between items",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Gap within items",
      "min": 5,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fffaf7"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon",
      "default": "#ff4315"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#761e0b"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#761e0b"
    },
    {
      "type": "header",
      "content": "Icon style"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "icon_stroke_width",
      "label": "Icon stroke width",
      "min": 1,
      "max": 3,
      "step": 0.5,
      "default": 2
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "header",
      "content": "Fast delivery"
    },
    {
      "type": "checkbox",
      "id": "show_fast_delivery",
      "label": "Show fast delivery",
      "default": true
    },
    {
      "type": "text",
      "id": "fast_delivery_title",
      "label": "Title",
      "default": "Fast Delivery"
    },
    {
      "type": "text",
      "id": "fast_delivery_text",
      "label": "Text",
      "default": "Quick dispatch on all orders"
    },
    {
      "type": "header",
      "content": "UK made"
    },
    {
      "type": "checkbox",
      "id": "show_uk_made",
      "label": "Show UK made",
      "default": true
    },
    {
      "type": "text",
      "id": "uk_made_title",
      "label": "Title",
      "default": "UK Made"
    },
    {
      "type": "text",
      "id": "uk_made_text",
      "label": "Text",
      "default": "Proudly manufactured in the UK"
    },
    {
      "type": "header",
      "content": "Giveback"
    },
    {
      "type": "checkbox",
      "id": "show_giveback",
      "label": "Show giveback",
      "default": true
    },
    {
      "type": "text",
      "id": "giveback_title",
      "label": "Title",
      "default": "5% Giveback"
    },
    {
      "type": "text",
      "id": "giveback_text",
      "label": "Text",
      "default": "Supporting rugby communities"
    },
    {
      "type": "header",
      "content": "Designed by players"
    },
    {
      "type": "checkbox",
      "id": "show_designed_by_players",
      "label": "Show designed by players",
      "default": true
    },
    {
      "type": "text",
      "id": "designed_by_players_title",
      "label": "Title",
      "default": "Player Designed"
    },
    {
      "type": "text",
      "id": "designed_by_players_text",
      "label": "Text",
      "default": "Created by players for players"
    }
  ],
  "presets": [
    {
      "name": "Trust signals"
    }
  ]
}
{% endschema %}
