{% doc %}
  @prompt
    i need trust signals, fast delivery, U
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-signals-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-trust-signals-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-trust-signal-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
    text-align: {{ block.settings.text_alignment }};
    {% if block.settings.text_alignment == 'center' %}
      flex-direction: column;
    {% endif %}
  }

  .ai-trust-signal-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-trust-signal-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
  }

  .ai-trust-signal-content-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-trust-signal-title-{{ ai_gen_id }} {
    margin: 0 0 4px 0;
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
  }

  .ai-trust-signal-text-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-trust-signals-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-trust-signal-item-{{ ai_gen_id }} {
      {% if block.settings.mobile_center %}
        text-align: center;
        flex-direction: column;
      {% endif %}
    }
  }
{% endstyle %}

<div class="ai-trust-signals-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-signals-grid-{{ ai_gen_id }}">
    {% if block.settings.show_delivery %}
      <div class="ai-trust-signal-item-{{ ai_gen_id }}">
        <div class="ai-trust-signal-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13"></rect>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
            <circle cx="5.5" cy="18.5" r="2.5"></circle>
            <circle cx="18.5" cy="18.5" r="2.5"></circle>
          </svg>
        </div>
        <div class="ai-trust-signal-content-{{ ai_gen_id }}">
          <div class="ai-trust-signal-title-{{ ai_gen_id }}">{{ block.settings.delivery_title }}</div>
          <div class="ai-trust-signal-text-{{ ai_gen_id }}">{{ block.settings.delivery_text }}</div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_returns %}
      <div class="ai-trust-signal-item-{{ ai_gen_id }}">
        <div class="ai-trust-signal-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 14 4 9 9 4"></polyline>
            <path d="M20 20v-7a4 4 0 0 0-4-4H4"></path>
          </svg>
        </div>
        <div class="ai-trust-signal-content-{{ ai_gen_id }}">
          <div class="ai-trust-signal-title-{{ ai_gen_id }}">{{ block.settings.returns_title }}</div>
          <div class="ai-trust-signal-text-{{ ai_gen_id }}">{{ block.settings.returns_text }}</div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_secure %}
      <div class="ai-trust-signal-item-{{ ai_gen_id }}">
        <div class="ai-trust-signal-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
        </div>
        <div class="ai-trust-signal-content-{{ ai_gen_id }}">
          <div class="ai-trust-signal-title-{{ ai_gen_id }}">{{ block.settings.secure_title }}</div>
          <div class="ai-trust-signal-text-{{ ai_gen_id }}">{{ block.settings.secure_text }}</div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_support %}
      <div class="ai-trust-signal-item-{{ ai_gen_id }}">
        <div class="ai-trust-signal-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
        </div>
        <div class="ai-trust-signal-content-{{ ai_gen_id }}">
          <div class="ai-trust-signal-title-{{ ai_gen_id }}">{{ block.settings.support_title }}</div>
          <div class="ai-trust-signal-text-{{ ai_gen_id }}">{{ block.settings.support_text }}</div>
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Trust signals",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "mobile_center",
      "label": "Center on mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between items",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Gap between icon and text",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fffaf7"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 20,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#ff4315"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#761e0b"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#761e0b"
    },
    {
      "type": "header",
      "content": "Fast delivery"
    },
    {
      "type": "checkbox",
      "id": "show_delivery",
      "label": "Show fast delivery",
      "default": true
    },
    {
      "type": "text",
      "id": "delivery_title",
      "label": "Title",
      "default": "Fast delivery"
    },
    {
      "type": "text",
      "id": "delivery_text",
      "label": "Text",
      "default": "2-3 day shipping"
    },
    {
      "type": "header",
      "content": "Easy returns"
    },
    {
      "type": "checkbox",
      "id": "show_returns",
      "label": "Show easy returns",
      "default": true
    },
    {
      "type": "text",
      "id": "returns_title",
      "label": "Title",
      "default": "Easy returns"
    },
    {
      "type": "text",
      "id": "returns_text",
      "label": "Text",
      "default": "30-day return policy"
    },
    {
      "type": "header",
      "content": "Secure checkout"
    },
    {
      "type": "checkbox",
      "id": "show_secure",
      "label": "Show secure checkout",
      "default": true
    },
    {
      "type": "text",
      "id": "secure_title",
      "label": "Title",
      "default": "Secure checkout"
    },
    {
      "type": "text",
      "id": "secure_text",
      "label": "Text",
      "default": "SSL encrypted payment"
    },
    {
      "type": "header",
      "content": "Customer support"
    },
    {
      "type": "checkbox",
      "id": "show_support",
      "label": "Show customer support",
      "default": true
    },
    {
      "type": "text",
      "id": "support_title",
      "label": "Title",
      "default": "24/7 support"
    },
    {
      "type": "text",
      "id": "support_text",
      "label": "Text",
      "default": "We're here to help"
    }
  ],
  "presets": [
    {
      "name": "Trust signals"
    }
  ]
}
{% endschema %}
