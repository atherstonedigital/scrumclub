{%- comment -%}
  sc-newsletter.liquid — Scrum Club newsletter sign-up (CLAUDE.md §3.4)
  ------------------------------------------------------------------
  "Join the club / First drops. No noise." Uses Shopify's customer form
  with a newsletter tag. Surface configurable; defaults to pitch.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign is_pitch = false
  if s.surface == 'pitch'
    assign is_pitch = true
  endif
-%}

<section class="sc-newsletter {% if is_pitch %}sc-pitch{% else %}sc-paper{% endif %}">
  <div class="sc-wrap sc-newsletter__grid">
    <div class="sc-newsletter__intro sc-reveal">
      {%- if s.eyebrow != blank -%}
        <p class="sc-eyebrow">{{ s.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if s.heading != blank -%}
        <h2 class="sc-h2 sc-newsletter__heading">{{ s.heading | escape }}</h2>
      {%- endif -%}
      {%- if s.body != blank -%}
        <div class="sc-body sc-newsletter__body">{{ s.body }}</div>
      {%- endif -%}
    </div>

    <div class="sc-newsletter__form-wrap">
      {%- form 'customer', class: 'sc-newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="sc-visually-hidden" for="sc-newsletter-email-{{ section.id }}">
          {{- s.placeholder | default: 'Email address' -}}
        </label>
        <input
          id="sc-newsletter-email-{{ section.id }}"
          class="sc-newsletter__input"
          type="email"
          name="contact[email]"
          placeholder="{{ s.placeholder | default: 'Email address' | escape }}"
          autocomplete="email"
          required
        >
        <button type="submit" class="sc-btn sc-btn--primary sc-newsletter__submit">
          {{- s.button_label | default: 'Join' | escape -}}
        </button>

        {%- if form.posted_successfully? -%}
          <p class="sc-small sc-newsletter__msg sc-newsletter__msg--ok" role="status">
            {{- s.success_message | default: "You're in. First drops incoming." -}}
          </p>
        {%- elsif form.errors -%}
          <p class="sc-small sc-newsletter__msg sc-newsletter__msg--err" role="alert">
            {{- form.errors | default_errors -}}
          </p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .sc-newsletter { padding-block: var(--section-y); }
  .sc-newsletter__grid {
    display: grid;
    gap: var(--s-6);
    align-items: end;
  }
  .sc-newsletter__heading { margin-block: var(--s-3) var(--s-4); }
  .sc-newsletter.sc-pitch .sc-newsletter__heading { color: var(--paper); }
  .sc-newsletter.sc-pitch .sc-newsletter__body { color: var(--fog); }

  .sc-newsletter__form { display: flex; flex-wrap: wrap; gap: var(--s-3); }
  .sc-newsletter__input {
    flex: 1 1 220px;
    min-width: 0;
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--steel);
    background: var(--paper);
    border: 1px solid var(--border);
    border-radius: var(--r-1);
    padding: 16px 18px;
  }
  .sc-newsletter__input:focus-visible { outline: 2px solid var(--try); outline-offset: 2px; }
  .sc-newsletter__submit { flex: 0 0 auto; }
  .sc-newsletter__msg { flex: 1 0 100%; margin-top: var(--s-2); }
  .sc-newsletter__msg--ok { color: var(--turf); }
  .sc-newsletter__msg--err { color: var(--try); }

  .sc-visually-hidden {
    position: absolute !important;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0);
    white-space: nowrap; border: 0;
  }

  @media (min-width: 900px) {
    .sc-newsletter__grid { grid-template-columns: 1fr 1fr; gap: var(--s-8); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SC Newsletter",
  "tag": "section",
  "class": "sc-section sc-newsletter-section",
  "settings": [
    {
      "type": "select",
      "id": "surface",
      "label": "Surface",
      "options": [
        { "value": "pitch", "label": "Pitch (dark)" },
        { "value": "paper", "label": "Paper (light)" }
      ],
      "default": "pitch"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "JOIN THE CLUB"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "First drops. No noise."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Early access to new kit, restocks and the research story. We email when it matters — not for the sake of it.</p>"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Join"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You're in. First drops incoming."
    }
  ],
  "presets": [
    {
      "name": "SC Newsletter"
    }
  ]
}
{% endschema %}
