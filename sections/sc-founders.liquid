{%- comment -%}
  sc-founders.liquid — founder profiles (CLAUDE.md §3.5)
  ------------------------------------------------------------------
  Block per founder: portrait (placeholder until shot — §7), name, role,
  bio. Seed copy adapted from the brand deck (pp.3–4); draft pending
  Sam & Nathan sign-off (§7).
{%- endcomment -%}

{%- liquid
  assign s = section.settings
-%}

<section class="sc-founders sc-paper">
  <div class="sc-wrap">
    {%- if s.heading != blank -%}
      <div class="sc-founders__head sc-reveal">
        {%- if s.eyebrow != blank -%}<p class="sc-eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
        <h2 class="sc-h2 sc-founders__title">{{ s.heading | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="sc-founders__grid">
      {%- for block in section.blocks -%}
        <article class="sc-founder sc-reveal" {{ block.shopify_attributes }}>
          <div class="sc-founder__media">
            {%- if block.settings.portrait != blank -%}
              {{ block.settings.portrait | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(min-width:800px) 45vw, 100vw', widths: '400,600,900', class: 'sc-founder__img', alt: block.settings.name }}
            {%- else -%}
              <div class="sc-founder__ph" aria-hidden="true"><span>Portrait TBC</span></div>
            {%- endif -%}
          </div>
          <div class="sc-founder__copy">
            {%- if block.settings.name != blank -%}<h3 class="sc-founder__name">{{ block.settings.name | escape }}</h3>{%- endif -%}
            {%- if block.settings.role != blank -%}<p class="sc-eyebrow sc-founder__role">{{ block.settings.role | escape }}</p>{%- endif -%}
            {%- if block.settings.bio != blank -%}<div class="sc-body sc-founder__bio">{{ block.settings.bio }}</div>{%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .sc-founders { padding-block: var(--section-y); }
  .sc-founders__head { max-width: 720px; margin-bottom: var(--s-7); }
  .sc-founders__title { margin-top: var(--s-2); }
  .sc-founders__grid { display: grid; grid-template-columns: 1fr; gap: var(--s-8); }
  .sc-founder { display: grid; gap: var(--s-5); }
  .sc-founder__img,
  .sc-founder__ph { width: 100%; aspect-ratio: 4 / 5; object-fit: cover; border-radius: var(--r-3); display: block; }
  .sc-founder__ph {
    display: flex; align-items: center; justify-content: center;
    background: repeating-linear-gradient(45deg, transparent 0 18px, rgba(0,0,0,0.03) 18px 19px), var(--bone);
  }
  .sc-founder__ph span {
    font-family: var(--font-mono); font-size: var(--fs-label); letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--grit); border: 1px dashed var(--grit);
    padding: 6px 10px; border-radius: var(--r-1);
  }
  .sc-founder__name { font-family: var(--font-display); text-transform: uppercase; font-size: var(--fs-h3); line-height: 1; }
  .sc-founder__role { margin: var(--s-2) 0 var(--s-4); }
  @media (min-width: 800px) {
    .sc-founders__grid { grid-template-columns: repeat(2, 1fr); gap: var(--s-7); }
    .sc-founder { grid-template-columns: 0.85fr 1.15fr; align-items: start; gap: var(--s-5); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SC Founders",
  "tag": "section",
  "class": "sc-section sc-founders-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "WHO WE ARE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built by two who play" }
  ],
  "blocks": [
    {
      "type": "founder",
      "name": "Founder",
      "settings": [
        { "type": "image_picker", "id": "portrait", "label": "Portrait" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "role", "label": "Role" },
        { "type": "richtext", "id": "bio", "label": "Bio" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "SC Founders",
      "blocks": [
        {
          "type": "founder",
          "settings": {
            "name": "Sam",
            "role": "CO-FOUNDER · FEM-FIT",
            "bio": "<p>Sam is a mental health nurse with 19 years in the NHS, a mother of two, and a second row who's now semi-retired from the pitch but still a devoted rugby mum, partner and grassroots club volunteer. Drawing on her own years in the pack, she designs rugby clothing engineered for the female form — so the next generation of players has the kit they deserve.</p>"
          }
        },
        {
          "type": "founder",
          "settings": {
            "name": "Nathan",
            "role": "CO-FOUNDER · PRODUCT",
            "bio": "<p>Nathan is a flight simulation engineer with 20 years in hardware innovation, building autonomous systems for industries worldwide. He's played and coached rugby for two decades, with a daughter who plays and a son who has too. He knows how expensive the sport can be — which is why he's set on rugby attire everyone can wear and afford.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
