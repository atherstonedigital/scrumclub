{%- comment -%}
  sc-size-guide.liquid — sizing table (CLAUDE.md §3.6 / §6 #2)
  ------------------------------------------------------------------
  One table per section instance (use two for Fem-Fit + Men-Fit). Columns
  and rows are schema-driven (pipe-separated cells). Measurements seed as
  TBC — real cm values + storage format are open (§6 #2); do NOT ship
  invented numbers (§0.5).
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign cols = s.columns | split: '|'
-%}

<section class="sc-sizeguide sc-paper">
  <div class="sc-wrap sc-sizeguide__inner">
    <div class="sc-sizeguide__head sc-reveal">
      {%- if s.eyebrow != blank -%}<p class="sc-eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="sc-h2 sc-sizeguide__title">{{ s.heading | escape }}</h2>{%- endif -%}
    </div>

    <div class="sc-sizeguide__scroll">
      <table class="sc-sizeguide__table">
        <thead>
          <tr>
            {%- for col in cols -%}<th scope="col">{{ col | strip | escape }}</th>{%- endfor -%}
          </tr>
        </thead>
        <tbody>
          {%- for block in section.blocks -%}
            {%- assign cells = block.settings.cells | split: '|' -%}
            <tr {{ block.shopify_attributes }}>
              {%- for cell in cells -%}
                {%- if forloop.first -%}
                  <th scope="row">{{ cell | strip | escape }}</th>
                {%- else -%}
                  <td>{{ cell | strip | escape }}</td>
                {%- endif -%}
              {%- endfor -%}
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>

    {%- if s.note != blank -%}<p class="sc-mono sc-sizeguide__note">{{ s.note | escape }}</p>{%- endif -%}
  </div>
</section>

{% stylesheet %}
  .sc-sizeguide { padding-block: var(--s-8); }
  .sc-sizeguide__inner { max-width: 820px; }
  .sc-sizeguide__head { margin-bottom: var(--s-5); }
  .sc-sizeguide__title { margin-top: var(--s-2); }
  .sc-sizeguide__scroll { overflow-x: auto; }
  .sc-sizeguide__table { width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: var(--fs-mono); }
  .sc-sizeguide__table th,
  .sc-sizeguide__table td { text-align: left; padding: var(--s-3) var(--s-4); border-bottom: 1px solid var(--bone); white-space: nowrap; }
  .sc-sizeguide__table thead th {
    font-family: var(--font-action); font-weight: 800; font-style: italic;
    text-transform: uppercase; letter-spacing: 0.06em; font-size: 13px;
    border-bottom: 2px solid var(--try);
  }
  .sc-sizeguide__table tbody th { color: var(--pitch); }
  .sc-sizeguide__note { margin-top: var(--s-4); color: var(--grit); }
{% endstylesheet %}

{% schema %}
{
  "name": "SC Size Guide",
  "tag": "section",
  "class": "sc-section sc-sizeguide-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "SIZING" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Fem-Fit" },
    { "type": "text", "id": "columns", "label": "Column headers", "info": "Pipe-separated.", "default": "Size|Chest (cm)|Length (cm)" },
    { "type": "text", "id": "note", "label": "Note", "default": "Measurements to be confirmed. Garment measured flat; allow for fit." }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        { "type": "text", "id": "cells", "label": "Cells", "info": "Pipe-separated, first cell is the size.", "default": "6|TBC|TBC" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SC Size Guide",
      "blocks": [
        { "type": "row", "settings": { "cells": "6|TBC|TBC" } },
        { "type": "row", "settings": { "cells": "8|TBC|TBC" } },
        { "type": "row", "settings": { "cells": "10|TBC|TBC" } },
        { "type": "row", "settings": { "cells": "12|TBC|TBC" } },
        { "type": "row", "settings": { "cells": "14|TBC|TBC" } }
      ]
    }
  ]
}
{% endschema %}
