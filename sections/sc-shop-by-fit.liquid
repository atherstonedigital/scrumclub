{%- comment -%}
  sc-shop-by-fit.liquid — "Shop by fit" tile grid (CLAUDE.md §3.4)
  ------------------------------------------------------------------
  Large linked tiles (Fem-Fit / Men-Fit in the mock). Block-based so the
  client can add/edit tiles. Image falls back to a placeholder.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign is_pitch = false
  if s.surface == 'pitch'
    assign is_pitch = true
  endif
-%}

<section class="sc-fit {% if is_pitch %}sc-pitch{% else %}sc-paper{% endif %}">
  <div class="sc-wrap">
    {%- if s.heading != blank -%}
      <p class="sc-eyebrow{% if is_pitch %} muted{% endif %} sc-fit__kicker">{{ s.heading | escape }}</p>
    {%- endif -%}
    <div class="sc-fit__grid">
      {%- for block in section.blocks -%}
        <a class="sc-fit__tile" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 1400
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 800px) 50vw, 100vw',
                widths: '600, 900, 1200, 1400',
                class: 'sc-fit__img',
                alt: block.settings.image.alt | default: block.settings.label
            }}
          {%- else -%}
            <span class="sc-fit__ph" aria-hidden="true"><span>Photo TBC</span></span>
          {%- endif -%}
          <span class="sc-fit__scrim" aria-hidden="true"></span>
          <span class="sc-fit__caption">
            {%- if block.settings.overline != blank -%}<span class="sc-eyebrow sc-fit__overline">{{ block.settings.overline | escape }}</span>{%- endif -%}
            <span class="sc-h2 sc-fit__label">{{ block.settings.label | escape }}</span>
            <span class="sc-fit__cta">{{ block.settings.cta | default: 'Browse' | escape }} →</span>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .sc-fit { padding-block: var(--section-y); }
  .sc-fit__kicker { margin-bottom: var(--s-5); }
  .sc-fit__grid { display: grid; grid-template-columns: 1fr; gap: var(--s-4); }
  .sc-fit__tile {
    --slash-length: clamp(180px, 34vw, 260px);
    --slash-thickness: clamp(14px, 2.6vw, 20px);
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--r-3);
    text-decoration: none;
    color: var(--paper);
  }
  .sc-fit__img,
  .sc-fit__ph {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sc-fit__ph { display: flex; align-items: center; justify-content: center; background: var(--mud); }
  .sc-fit__ph span {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fog);
    border: 1px dashed var(--grit);
    padding: 6px 10px;
    border-radius: var(--r-1);
  }
  .sc-fit__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(11, 11, 14, 0.1), rgba(11, 11, 14, 0.7));
  }
  /* Corner slash — brand guidelines p.24: one solid try-red bar per card,
     -22deg, anchored across the top-right corner and clipped by the tile.
     Fully opaque, never a translucent overlay on the photo. */
  .sc-fit__tile::after {
    content: "";
    position: absolute;
    top: -20px;
    right: -24px;
    width: var(--slash-length);
    height: var(--slash-thickness);
    background: var(--try);
    transform: rotate(-22deg);
    transform-origin: top right;
    transition: width var(--dur-fast) var(--ease-tackle);
    pointer-events: none;
    z-index: 2;
  }
  .sc-fit__tile:hover::after,
  .sc-fit__tile:focus-visible::after {
    width: calc(var(--slash-length) + 8px);
  }
  .sc-fit__caption {
    position: absolute;
    left: var(--s-6);
    bottom: var(--s-6);
    right: var(--s-6);
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .sc-fit__overline { color: var(--paper); }
  .sc-fit__label { color: var(--paper); }
  .sc-fit__cta {
    font-family: var(--font-action);
    font-weight: 800;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 14px;
  }
  .sc-fit__tile:hover .sc-fit__cta { color: var(--try-bright); }
  @media (min-width: 800px) {
    .sc-fit__grid { grid-template-columns: repeat(2, 1fr); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SC Shop By Fit",
  "tag": "section",
  "class": "sc-section sc-fit-section",
  "settings": [
    {
      "type": "select",
      "id": "surface",
      "label": "Surface",
      "options": [
        { "value": "paper", "label": "Paper (light)" },
        { "value": "pitch", "label": "Pitch (dark)" }
      ],
      "default": "paper"
    },
    { "type": "text", "id": "heading", "label": "Kicker", "default": "SHOP BY FIT" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Fit tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "overline", "label": "Overline" },
        { "type": "text", "id": "label", "label": "Label", "default": "Fem-Fit" },
        { "type": "text", "id": "cta", "label": "CTA text", "default": "Browse" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "SC Shop By Fit",
      "blocks": [
        { "type": "tile", "settings": { "label": "Fem-Fit", "cta": "Browse" } },
        { "type": "tile", "settings": { "label": "Men-Fit", "cta": "Browse" } }
      ]
    }
  ]
}
{% endschema %}
