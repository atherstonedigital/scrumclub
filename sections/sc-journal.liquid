{%- comment -%}
  sc-journal.liquid — blog posts row (CLAUDE.md §3.4)
  ------------------------------------------------------------------
  3-up grid of articles from a chosen blog. Category from the article's
  first tag; read time estimated from word count. Placeholders when no
  blog is connected (§0.5).
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign blog = blogs[s.blog]
  assign limit = s.post_limit
-%}

<section class="sc-journal sc-paper">
  <div class="sc-wrap">
    <div class="sc-journal__head sc-reveal">
      <div>
        {%- if s.eyebrow != blank -%}<p class="sc-eyebrow">{{ s.eyebrow | escape }}</p>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="sc-h2 sc-journal__heading">{{ s.heading | escape }}</h2>{%- endif -%}
      </div>
      {%- if s.link_label != blank and blog != blank -%}
        <a class="sc-journal__all" href="{{ blog.url }}">{{ s.link_label | escape }} →</a>
      {%- endif -%}
    </div>

    <div class="sc-journal__grid">
      {%- if blog != blank and blog.articles_count > 0 -%}
        {%- for article in blog.articles limit: limit -%}
          {%- liquid
            assign words = article.content | strip_html | split: ' ' | size
            assign mins = words | divided_by: 200 | at_least: 1
            assign category = article.tags.first | default: s.eyebrow
          -%}
          <a class="sc-journal__card sc-card" href="{{ article.url }}">
            <span class="sc-journal__media">
              {%- if article.image != blank -%}
                {{ article.image | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width:800px) 33vw, 100vw', widths: '300,450,600,800', class: 'sc-journal__img', alt: article.image.alt | default: article.title }}
              {%- else -%}
                <span class="sc-journal__ph"><span>Photo TBC</span></span>
              {%- endif -%}
            </span>
            <span class="sc-journal__body">
              <span class="sc-eyebrow sc-journal__meta">{{ category | escape }} · {{ mins }} min read</span>
              <span class="sc-journal__title">{{ article.title | escape }}</span>
              <span class="sc-small sc-journal__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 22 }}</span>
            </span>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <span class="sc-journal__card sc-card">
            <span class="sc-journal__media"><span class="sc-journal__ph"><span>Photo TBC</span></span></span>
            <span class="sc-journal__body">
              <span class="sc-eyebrow sc-journal__meta">Field notes · 4 min read</span>
              <span class="sc-journal__title">Story headline {{ i }}</span>
              <span class="sc-small sc-journal__excerpt">Connect a blog in the editor to populate the Journal with real posts.</span>
            </span>
          </span>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .sc-journal { padding-block: var(--section-y); }
  .sc-journal__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--s-4);
    margin-bottom: var(--s-6);
  }
  .sc-journal__heading { margin-top: var(--s-2); }
  .sc-journal__all {
    font-family: var(--font-action);
    font-weight: 800;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 14px;
    color: var(--try);
    text-decoration: none;
    white-space: nowrap;
  }
  .sc-journal__grid { display: grid; grid-template-columns: 1fr; gap: var(--s-5); }
  .sc-journal__card { display: flex; flex-direction: column; text-decoration: none; color: inherit; background: var(--paper); }
  .sc-journal__img,
  .sc-journal__ph { width: 100%; aspect-ratio: 16 / 10; object-fit: cover; display: block; }
  .sc-journal__ph {
    display: flex;
    align-items: center;
    justify-content: center;
    background: repeating-linear-gradient(45deg, transparent 0 16px, rgba(0,0,0,0.03) 16px 17px), var(--bone);
  }
  .sc-journal__ph span {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--grit);
    border: 1px dashed var(--grit);
    padding: 5px 9px;
    border-radius: var(--r-1);
  }
  .sc-journal__body { padding: var(--s-4) var(--s-4) var(--s-5); display: flex; flex-direction: column; gap: var(--s-2); }
  .sc-journal__title { font-family: var(--font-display); text-transform: uppercase; font-size: var(--fs-h3); line-height: 1; }
  .sc-journal__excerpt { color: var(--grit); }
  @media (min-width: 800px) {
    .sc-journal__grid { grid-template-columns: repeat(3, 1fr); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SC Journal",
  "tag": "section",
  "class": "sc-section sc-journal-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FROM THE CLUB" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Journal" },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "post_limit", "label": "Posts shown", "min": 2, "max": 6, "step": 1, "default": 3 },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "All stories" }
  ],
  "presets": [ { "name": "SC Journal" } ]
}
{% endschema %}
