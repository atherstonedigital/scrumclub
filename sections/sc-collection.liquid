{%- comment -%}
  sc-collection.liquid — collection / PLP (CLAUDE.md §3.6)
  ------------------------------------------------------------------
  Rides Shopify's native filtering + sorting + pagination, rendered
  brand-side with sc-product-card. The fem/men fit filter is surfaced as a
  prominent bar; remaining list filters render as chips. Filtering is
  link-based (no JS); sorting is a JS-enhanced select.

  The fit bar + chips appear once the relevant filters are enabled in admin
  (Search & Discovery). The fit filter expects the `scc.fit` metafield as a
  storefront filter (§6 #1). Degrades to placeholders when empty.
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign per = s.products_per_page

  assign fit_filter = null
  for f in collection.filters
    if f.param_name contains 'scc.fit' or f.label == 'Fit'
      assign fit_filter = f
    endif
  endfor
-%}

{{ 'sc-product-card.css' | asset_url | stylesheet_tag }}

<section class="sc-plp sc-paper">
  <div class="sc-wrap">
    <header class="sc-plp__head sc-reveal">
      <p class="sc-eyebrow">{{ s.eyebrow | default: 'SHOP' | escape }}</p>
      <h1 class="sc-h1 sc-plp__title">{{ collection.title | default: 'Collection' | escape }}</h1>
      {%- if collection.description != blank and s.show_description -%}
        <div class="sc-body sc-plp__desc">{{ collection.description }}</div>
      {%- endif -%}
    </header>

    {%- comment -%} Fit bar — the primary fem/men axis {%- endcomment -%}
    {%- if fit_filter -%}
      <div class="sc-plp__fit" role="group" aria-label="Filter by fit">
        <a class="sc-pill sc-plp__fit-pill{% unless fit_filter.active_values.size > 0 %} sc-pill--active{% endunless %}" href="{{ fit_filter.url_to_remove }}">All</a>
        {%- for value in fit_filter.values -%}
          <a class="sc-pill sc-plp__fit-pill{% if value.active %} sc-pill--active{% endif %}"
             href="{% if value.active %}{{ value.url_to_remove }}{% else %}{{ value.url_to_add }}{% endif %}">
            {{ value.label | escape }}
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Toolbar: other filters + count + sort {%- endcomment -%}
    <div class="sc-plp__bar">
      <div class="sc-plp__filters">
        {%- for f in collection.filters -%}
          {%- if fit_filter and f.param_name == fit_filter.param_name -%}{% continue %}{%- endif -%}
          {%- if f.type == 'list' or f.type == 'boolean' -%}
            {%- for value in f.values -%}
              {%- if value.count > 0 or value.active -%}
                <a class="sc-chip{% if value.active %} sc-chip--active{% endif %}"
                   href="{% if value.active %}{{ value.url_to_remove }}{% else %}{{ value.url_to_add }}{% endif %}">
                  {{ f.label | escape }}: {{ value.label | escape }}{% if value.active %} ✕{% endif %}
                </a>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="sc-plp__tools">
        <span class="sc-mono sc-plp__count">{{ collection.products_count }} item{% if collection.products_count != 1 %}s{% endif %}</span>
        {%- if collection.sort_options.size > 0 -%}
          <form class="sc-plp__sortform" data-sc-sort>
            <label class="sc-visually-hidden" for="sc-sort-{{ section.id }}">Sort</label>
            <select id="sc-sort-{{ section.id }}" name="sort_by" class="sc-plp__sort">
              {%- assign sort_now = collection.sort_by | default: collection.default_sort_by -%}
              {%- for opt in collection.sort_options -%}
                <option value="{{ opt.value }}" {% if opt.value == sort_now %}selected{% endif %}>{{ opt.name | escape }}</option>
              {%- endfor -%}
            </select>
          </form>
        {%- endif -%}
      </div>
    </div>

    {%- paginate collection.products by per -%}
      {%- if collection.products.size > 0 -%}
        <div class="sc-plp__grid">
          {%- for product in collection.products -%}
            {%- render 'sc-product-card', product: product -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="sc-plp__pager" aria-label="Pagination">
            {%- if paginate.previous -%}<a class="sc-plp__page" href="{{ paginate.previous.url }}">← Prev</a>{%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a class="sc-plp__page" href="{{ part.url }}">{{ part.title }}</a>
              {%- else -%}
                <span class="sc-plp__page sc-plp__page--current" aria-current="page">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}<a class="sc-plp__page" href="{{ paginate.next.url }}">Next →</a>{%- endif -%}
          </nav>
        {%- endif -%}
      {%- elsif collection.all_products_count > 0 -%}
        <div class="sc-plp__empty">
          <p class="sc-body">No products match these filters.</p>
          <a class="sc-btn sc-btn--ghost" href="{{ collection.url }}">Clear filters</a>
        </div>
      {%- else -%}
        <div class="sc-plp__grid">
          {%- for i in (1..4) -%}
            <article class="sc-card sc-pcard">
              <div class="sc-pcard__media"><div class="sc-pcard__ph"><span>Photo TBC</span></div></div>
              <div class="sc-pcard__body">
                <p class="sc-eyebrow sc-pcard__eyebrow">FEM-FIT · MATCH</p>
                <h3 class="sc-pcard__title"><a href="#">Product {{ i }}</a></h3>
                <p class="sc-pcard__price">£00</p>
              </div>
            </article>
          {%- endfor -%}
        </div>
        <p class="sc-mono sc-plp__note">Add products to this collection to populate the grid.</p>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% stylesheet %}
  .sc-plp { padding-block: var(--section-y-tight) var(--section-y); }
  .sc-plp__head { max-width: 760px; margin-bottom: var(--s-6); }
  .sc-plp__title { margin-top: var(--s-2); }
  .sc-plp__desc { margin-top: var(--s-4); }

  .sc-plp__fit { display: flex; flex-wrap: wrap; gap: var(--s-2); margin-bottom: var(--s-5); }

  .sc-plp__bar {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
    gap: var(--s-4); padding-block: var(--s-4);
    border-top: 1px solid var(--bone); border-bottom: 1px solid var(--bone);
    margin-bottom: var(--s-6);
  }
  .sc-plp__filters { display: flex; flex-wrap: wrap; gap: var(--s-2); }
  .sc-chip {
    font-family: var(--font-mono); font-size: 12px; text-decoration: none;
    color: var(--steel); border: 1px solid var(--bone); border-radius: var(--r-1);
    padding: 4px 10px;
  }
  .sc-chip--active { background: var(--pitch); color: var(--paper); border-color: var(--pitch); }
  .sc-plp__tools { display: flex; align-items: center; gap: var(--s-4); }
  .sc-plp__count { color: var(--grit); }
  .sc-plp__sort {
    font-family: var(--font-action); font-weight: 800; font-style: italic;
    text-transform: uppercase; letter-spacing: 0.04em; font-size: 16px; /* >=16px: avoids iOS focus-zoom */
    color: var(--pitch); background: var(--paper);
    border: 1px solid var(--bone); border-radius: var(--r-1); padding: 8px 12px; cursor: pointer;
  }

  .sc-plp__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--s-4); }
  @media (min-width: 900px) { .sc-plp__grid { grid-template-columns: repeat(4, 1fr); gap: var(--s-5); } }

  .sc-plp__empty { padding: var(--s-9) 0; text-align: left; display: flex; flex-direction: column; gap: var(--s-4); align-items: flex-start; }
  .sc-plp__note { margin-top: var(--s-5); color: var(--grit); }

  .sc-plp__pager { display: flex; flex-wrap: wrap; gap: var(--s-2); margin-top: var(--s-8); }
  .sc-plp__page {
    font-family: var(--font-mono); font-size: 13px; text-decoration: none;
    color: var(--steel); border: 1px solid var(--bone); border-radius: var(--r-1);
    padding: 8px 12px; min-width: 40px; text-align: center;
  }
  .sc-plp__page--current { background: var(--try); color: var(--paper); border-color: var(--try); }

  .sc-visually-hidden { position: absolute !important; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0; }
{% endstylesheet %}

{% javascript %}
  (function () {
    document.querySelectorAll('[data-sc-sort] select').forEach(function (sel) {
      sel.addEventListener('change', function () {
        var url = new URL(window.location.href);
        url.searchParams.set('sort_by', sel.value);
        url.searchParams.delete('page');
        window.location.href = url.toString();
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "SC Collection",
  "tag": "section",
  "class": "sc-section sc-collection-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "SHOP" },
    { "type": "checkbox", "id": "show_description", "label": "Show collection description", "default": true },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 8, "max": 24, "step": 4, "default": 12 }
  ],
  "presets": [ { "name": "SC Collection" } ]
}
{% endschema %}
