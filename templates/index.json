/*
 * Scrum Club homepage — intentionally Git-authored (CLAUDE.md §0.2).
 * Places the sc-* home sections in the mock's order. Because this file is
 * now owned in Git, manage the homepage layout from ONE source: if you
 * rearrange/merchandise it in the Shopify editor, pull it back and commit
 * (or tell Claude) so the two don't drift and clobber each other.
 */
{
  "sections": {
    "announcement": {
      "type": "sc-announcement",
      "settings": {
        "surface": "pitch",
        "text": "MADE IN UK|5% OF EVERY ORDER FUNDS RESEARCH|FREE UK SHIPPING OVER £75"
      }
    },
    "hero": {
      "type": "sc-home-hero",
      "settings": {
        "surface": "pitch",
        "min_height": 88,
        "eyebrow": "AW26 · MATCHDAY DROP",
        "headline": "Built for the women's game.",
        "subcopy": "<p>Rugby kit and protective wear drafted from a women's body block — not shrunk down from a men's one. Tested in the mud. Made in the UK.</p>",
        "cta_primary_label": "Shop the range",
        "cta_secondary_label": "Explore Fem-Fit",
        "overlay_opacity": 55
      }
    },
    "marquee": {
      "type": "sc-marquee",
      "settings": {
        "surface": "try",
        "text": "PLAY STRONG.|LOOK FIERCE.|BE UNSTOPPABLE.",
        "separator": "/",
        "speed": 26
      }
    },
    "featured": {
      "type": "sc-featured-collection",
      "settings": {
        "eyebrow": "IN STOCK NOW · NEW IN",
        "heading": "Matchday picks",
        "product_limit": 4,
        "link_label": "Shop all"
      }
    },
    "femfit": {
      "type": "sc-media-text",
      "settings": {
        "surface": "paper",
        "image_position": "left",
        "eyebrow": "THE MATCH RANGE · FEM-FIT",
        "heading": "Cut for the way you play.",
        "body": "<p>Drafted from a women's body block and photographed independently — never resized from the men's line. Two-way stretch, mud-tolerant, built to last a season of contact.</p>",
        "cta_label": "Shop Fem-Fit",
        "placeholder_label": "Photography TBC — Fem-Fit on-body"
      }
    },
    "shopbyfit": {
      "type": "sc-shop-by-fit",
      "settings": {
        "surface": "paper",
        "heading": "SHOP BY FIT"
      },
      "blocks": {
        "fem": {
          "type": "tile",
          "settings": { "overline": "WOMEN'S", "label": "Fem-Fit", "cta": "Browse" }
        },
        "men": {
          "type": "tile",
          "settings": { "overline": "MEN'S", "label": "Men-Fit", "cta": "Browse" }
        }
      },
      "block_order": ["fem", "men"]
    },
    "look": {
      "type": "sc-shop-the-look",
      "settings": {
        "eyebrow": "LOOKBOOK",
        "heading": "Shop the kit",
        "body": "<p>The full matchday look, built to be worn together. Tap a piece to shop it.</p>",
        "cta_label": "View the lookbook"
      },
      "blocks": {
        "h1": { "type": "hotspot", "settings": { "x": 38, "y": 30 } },
        "h2": { "type": "hotspot", "settings": { "x": 58, "y": 62 } }
      },
      "block_order": ["h1", "h2"]
    },
    "commitment": {
      "type": "sc-media-text",
      "settings": {
        "surface": "pitch",
        "image_position": "right",
        "stat": "5%",
        "eyebrow": "WHY WE EXIST",
        "heading": "A cut of every order, every year.",
        "body": "<p>Five percent of every order funds research into women's rugby — injury prevention, performance, participation. Audited annually and reported in the open. Not a campaign. A standing commitment.</p>",
        "cta_label": "Read the commitment",
        "placeholder_label": "Photography TBC"
      }
    },
    "journal": {
      "type": "sc-journal",
      "settings": {
        "eyebrow": "FROM THE CLUB",
        "heading": "Journal",
        "post_limit": 3,
        "link_label": "All stories"
      }
    },
    "trust": {
      "type": "sc-trust-row",
      "settings": { "surface": "paper" },
      "blocks": {
        "made": {
          "type": "item",
          "settings": {
            "title": "Made in the UK",
            "text": "Cut and sewn in Britain. \"MADE IN UK\" on every label."
          }
        },
        "research": {
          "type": "item",
          "settings": { "title": "5% to research", "text": "Audited annually, reported openly." }
        },
        "tested": {
          "type": "item",
          "settings": { "title": "Contact-tested", "text": "Protective wear trialled by club players." }
        },
        "fulfilled": {
          "type": "item",
          "settings": { "title": "Self-fulfilled", "text": "Packed and shipped by us. Free UK over £75." }
        }
      },
      "block_order": ["made", "research", "tested", "fulfilled"]
    },
    "newsletter": {
      "type": "sc-newsletter",
      "settings": {
        "surface": "pitch",
        "eyebrow": "JOIN THE CLUB",
        "heading": "First drops. No noise.",
        "body": "<p>Early access to new kit, restocks and the research story. We email when it matters — not for the sake of it.</p>",
        "button_label": "Join"
      }
    }
  },
  "order": [
    "announcement",
    "hero",
    "marquee",
    "featured",
    "femfit",
    "shopbyfit",
    "look",
    "commitment",
    "journal",
    "trust",
    "newsletter"
  ]
}
