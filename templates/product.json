/*
 * Scrum Club PDP — Git-authored (CLAUDE.md §0.2 / §3.2).
 * Keeps Pitch's functional blocks (media gallery, variant-picker,
 * buy-buttons) for cart/variant logic; swaps in brand blocks for the
 * eyebrow, title, spec line and 5% signal. Native variant/CTA colours are
 * set here via each block's own settings (the Horizon-native way); brand
 * layout/type/cut-shadow come from assets/sc-pdp.css.
 */
{
  "sections": {
    "main": {
      "type": "product-information",
      "blocks": {
        "media-gallery": {
          "type": "_product-media-gallery",
          "static": true,
          "settings": {
            "media_presentation": "grid",
            "media_columns": "one",
            "image_gap": 1,
            "large_first_image": false,
            "icons_style": "arrow",
            "thumbnail_position": "bottom",
            "thumbnail_width": 44,
            "thumbnail_radius": 0,
            "aspect_ratio": "0.8",
            "constrain_to_viewport": true,
            "media_fit": "cover",
            "media_radius": 8,
            "extend_media": false,
            "zoom": true,
            "hide_variants": false
          },
          "blocks": {}
        },
        "product-details": {
          "type": "_product-details",
          "static": true,
          "settings": {
            "width": "custom",
            "custom_width": 92,
            "width_mobile": "fill",
            "custom_width_mobile": 100,
            "height": "fit",
            "details_position": "flex-start",
            "gap": 0,
            "sticky_details_desktop": true,
            "background_media": "none",
            "background_color": "",
            "border": "none",
            "border_radius": 0,
            "padding-block-start": 56,
            "padding-block-end": 24,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "group_main": {
              "type": "group",
              "name": "Main information",
              "settings": {
                "content_direction": "column",
                "vertical_on_mobile": true,
                "horizontal_alignment": "flex-start",
                "vertical_alignment": "center",
                "horizontal_alignment_flex_direction_column": "flex-start",
                "vertical_alignment_flex_direction_column": "center",
                "gap": 8,
                "width": "fill",
                "custom_width": 100,
                "width_mobile": "fill",
                "custom_width_mobile": 100,
                "height": "fit",
                "background_media": "none",
                "background_color": "",
                "border": "none",
                "border_radius": 0,
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {
                "sc_eyebrow": { "type": "sc-pdp-eyebrow", "settings": {}, "blocks": {} },
                "sc_title": { "type": "sc-pdp-title", "settings": {}, "blocks": {} },
                "price": {
                  "type": "price",
                  "settings": {
                    "show_sale_price_first": true,
                    "show_installments": true,
                    "show_tax_info": true,
                    "type_preset": "h6",
                    "width": "100%",
                    "alignment": "left",
                    "font": "var(--font-body--family)",
                    "font_size": "1.25rem",
                    "padding-block-start": 8,
                    "padding-block-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": ["sc_eyebrow", "sc_title", "price"]
            },
            "group_form": {
              "type": "group",
              "name": "Product form",
              "settings": {
                "content_direction": "column",
                "vertical_on_mobile": true,
                "horizontal_alignment": "flex-start",
                "vertical_alignment": "center",
                "horizontal_alignment_flex_direction_column": "flex-start",
                "vertical_alignment_flex_direction_column": "center",
                "gap": 24,
                "width": "fill",
                "custom_width": 100,
                "width_mobile": "fill",
                "custom_width_mobile": 100,
                "height": "fit",
                "background_media": "none",
                "background_color": "",
                "border": "none",
                "border_radius": 0,
                "padding-block-start": 24,
                "padding-block-end": 8,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {
                "variant_picker": {
                  "type": "variant-picker",
                  "settings": {
                    "variant_style": "buttons",
                    "show_swatches": true,
                    "variant_style_class": "custom",
                    "custom_variant_background": "#F4F1EC",
                    "custom_variant_text": "#0B0B0E",
                    "custom_variant_border": "#D4CFC2",
                    "selected_variant_style_class": "custom",
                    "custom_selected_variant_background": "#0B0B0E",
                    "custom_selected_variant_text": "#F4F1EC",
                    "custom_selected_variant_border": "#0B0B0E",
                    "alignment": "left"
                  },
                  "blocks": {}
                },
                "buy_buttons": {
                  "type": "buy-buttons",
                  "settings": {
                    "stacking": false,
                    "show_pickup_availability": false,
                    "gift_card_form": false,
                    "input_style": "default",
                    "border_width": 1,
                    "border_radius": 2
                  },
                  "blocks": {
                    "quantity": {
                      "type": "quantity",
                      "static": true,
                      "settings": { "input_style": "default", "border_width": 1, "border_radius": 2 },
                      "blocks": {}
                    },
                    "add-to-cart": {
                      "type": "add-to-cart",
                      "static": true,
                      "settings": {
                        "style_class": "button-custom",
                        "custom_button_background": "#E1261C",
                        "custom_button_text": "#F4F1EC",
                        "custom_button_border": "#E1261C"
                      },
                      "blocks": {}
                    },
                    "accelerated-checkout": {
                      "type": "accelerated-checkout",
                      "static": true,
                      "settings": {},
                      "blocks": {}
                    }
                  },
                  "block_order": []
                }
              },
              "block_order": ["variant_picker", "buy_buttons"]
            },
            "sc_spec": { "type": "sc-pdp-spec", "settings": {}, "blocks": {} },
            "sc_trust": { "type": "sc-trust-5pct", "settings": {}, "blocks": {} },
            "description": {
              "type": "text",
              "name": "Product description",
              "settings": {
                "text": "{{ closest.product.description }}",
                "width": "100%",
                "max_width": "normal",
                "alignment": "left",
                "type_preset": "paragraph",
                "font": "var(--font-body--family)",
                "wrap": "pretty",
                "padding-block-start": 16,
                "padding-block-end": 24
              },
              "blocks": {}
            },
            "disclosures": {
              "type": "disclosures",
              "name": "Disclosures",
              "settings": {
                "heading": "Details & care",
                "heading_preset": "h6",
                "open_by_default": false,
                "icon": "caret",
                "disclosure_heading_preset": "h6",
                "dividers": true,
                "padding-block-start": 24,
                "padding-block-end": 16
              },
              "blocks": {}
            }
          },
          "block_order": ["group_main", "group_form", "sc_spec", "sc_trust", "description", "disclosures"]
        }
      },
      "settings": {
        "content_width": "content-full-width",
        "desktop_media_position": "left",
        "equal_columns": true,
        "limit_details_width": true,
        "gap": 0,
        "enable_sticky_add_to_cart": true,
        "background_color": "#F4F1EC",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "marquee": {
      "type": "sc-marquee",
      "settings": {
        "surface": "try",
        "text": "MADE IN UK|5% TO RESEARCH|CONTACT-TESTED|FREE UK SHIPPING OVER £75",
        "separator": "/",
        "speed": 30
      }
    },
    "recommendations": {
      "type": "product-recommendations",
      "blocks": {
        "header": {
          "type": "text",
          "name": "Header",
          "settings": {
            "text": "<h3>Complete the kit</h3>",
            "width": "fit-content",
            "max_width": "normal",
            "alignment": "left",
            "type_preset": "rte",
            "font": "var(--font-body--family)"
          },
          "blocks": {}
        }
      },
      "block_order": ["header"],
      "name": "Product recommendations",
      "settings": {
        "product": "{{ closest.product }}",
        "recommendation_type": "related",
        "layout_type": "grid",
        "carousel_on_mobile": false,
        "max_products": 4,
        "columns": 4,
        "mobile_columns": "2",
        "columns_gap": 12,
        "rows_gap": 36,
        "section_width": "page-width",
        "gap": 28,
        "background_color": "#F4F1EC",
        "padding-block-start": 64,
        "padding-block-end": 64
      }
    }
  },
  "order": ["main", "marquee", "recommendations"]
}
